# .env.example — copy to .env and fill in your values
# OR run: python aegis.py setup

# ── AI Provider: OpenRouter ──────────────────────────────────────────────
# Get your free API key at: https://openrouter.ai/keys
OPENROUTER_API_KEY="sk-or-your_openrouter_api_key_here"

# LLM Model — see https://openrouter.ai/models for all options
# Free/cheap options: qwen/qwen2.5-72b-instruct, mistralai/mistral-7b-instruct
# Paid options: openai/gpt-4o, anthropic/claude-3.5-sonnet
AEGIS_MODEL="qwen/qwen2.5-72b-instruct"

# ── API Settings ─────────────────────────────────────────────────────────
# Request timeout for AI API calls (seconds)
AEGIS_API_TIMEOUT=60

# Maximum AI API retries on failure
AEGIS_API_RETRIES=3

# ── Scan Settings ────────────────────────────────────────────────────────
# Default scan profile (quick|full|web|stealth)
AEGIS_DEFAULT_PROFILE="full"

# Default wordlist path for gobuster
AEGIS_WORDLIST="/usr/share/wordlists/dirb/common.txt"

# Nmap timeout (seconds)
AEGIS_NMAP_TIMEOUT=600

# ── Output ───────────────────────────────────────────────────────────────
# Reports output directory
AEGIS_REPORTS_DIR="./reports"

# Enable debug logging (true|false)
AEGIS_DEBUG="false"
